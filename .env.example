# KhidmatAI Environment Variables Example

# Gemini API Key (Required for AI features)
GEMINI_API_KEY=AIzaSyCdsOCgw5xwmCZhCGG1BEcrJEZfRh5xgVk

# Port for the Node.js Express server (Cloud Run uses 8080)
PORT=8080

# Firebase Service Account JSON (Required if using Cloud Firestore backend instead of memory mock)
# Format should be a one-line JSON string representing the service account credential file.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}
